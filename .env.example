# ── LLM Keys (use whichever ADK you're running) ──────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...               # for Google ADK / Gemini

# ── Database (for live schema introspection) ──────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# ── SQLMind config ────────────────────────────────────────────────────────────
SQLMIND_DIALECT=postgresql       # default dialect
SQLMIND_SCHEMA_PATH=schema.sqlmind.yaml

# ── LangSmith (optional — for LangGraph tracing) ─────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=sqlmind
